{
  "name": "my-mcp-server",
  "version": "1.0.0",
  "description": "An MCP server",
  "type": "module",
  "main": "dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./cli": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "my-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "license:check": "node scripts/check-licenses.mjs",
    "lint": "eslint src/",
    "smoke:mcp": "npm run build && node scripts/mcp-smoke.mjs",
    "pack:check": "npm run build && node scripts/verify-pack.mjs",
    "template:check": "node scripts/verify-template-ready.mjs",
    "pretest": "npm run build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage --runInBand",
    "prepublishOnly": "npm run template:check && npm test && npm run smoke:mcp && npm run pack:check",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "version:sync": "node -e \"console.log(JSON.parse(require('fs').readFileSync('package.json','utf8')).version)\""
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@types/node": "^22.19.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "overrides": {
    "fast-uri": "^3.1.1",
    "hono": "^4.12.18",
    "ip-address": "^10.2.0",
    "express-rate-limit": "^8.5.1"
  }
}
